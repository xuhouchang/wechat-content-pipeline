# WeChat Official Account API credentials
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# Serper.dev API Key for Google search
SERPER_API_KEY=your_serper_key_here

# AnySearch API Key for fallback search
ANYSEARCH_API_KEY=your_anysearch_key_here

# LLM API Keys (DeepSeek, OpenAI-compatible)
DEEPSEEK_API_KEY=your_deepseek_key_here
LLM_API_KEY=your_llm_key_here

# Optional: Preferred model overrides
# MODEL_WRITING=openai/gpt-5.4
# MODEL_POLISH=openai/gpt-5.4
# MODEL_CASE=deepseek/deepseek-chat
